# ── Qdrant Vector DB (Qdrant Cloud) ───────────────────────────────────────
# Get QDRANT_URL and QDRANT_API_KEY from: https://cloud.qdrant.io
QDRANT_URL=https://<cluster-id>.us-east4-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key-here
QDRANT_COLLECTION=scholarships

# ── Redis Cache (Upstash Redis — optional) ────────────────────────────────
# Get REDIS_URL from: https://upstash.com  (create a Redis database)
REDIS_URL=rediss://:<password>@<endpoint>.upstash.io:6380

# ── PostgreSQL (Neon PostgreSQL) ──────────────────────────────────────────
# Get DATABASE_URL from: https://neon.tech  (create a project → connection string)
POSTGRES_URL=postgresql+asyncpg://<user>:<password>@<host>.neon.tech/neondb?ssl=require

# ── Google Gemini (Google AI Studio) ─────────────────────────────────────
# Get GEMINI_API_KEY from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── JWT Auth ──────────────────────────────────────────────────────────────
# Generate a strong random secret, e.g.: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── Embedding Model ───────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
